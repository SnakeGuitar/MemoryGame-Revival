<Page x:Class="MemoryGame.Client.Mockups.TitleScreenMockup"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:MemoryGame.Client.Mockups"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Login">

    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="/Resources/Images/Backgrounds/background-minimalistic.png"/>
        </Grid.Background>
        <Rectangle HorizontalAlignment="Left" Height="200" Margin="291,-10,0,0" VerticalAlignment="Top" Width="200">
            <Rectangle.Fill>
                <ImageBrush ImageSource="/Resources/Images/Logos/logo-en.png"/>
            </Rectangle.Fill>
        </Rectangle>
        <Button Content="Already have an account?" HorizontalAlignment="Left" Height="34" Margin="283,278,0,0" VerticalAlignment="Top" Width="215" Foreground="#FFAF1010" BorderBrush="{x:Null}" Background="{x:Null}"/>
        <Button Content="Sign up" HorizontalAlignment="Left" Height="34" Margin="283,227,0,0" VerticalAlignment="Top" Width="215" Foreground="White" BorderBrush="{x:Null}">
            <Button.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#FFC84747"/>
                    <GradientStop Color="#FF963B3B" Offset="1"/>
                </LinearGradientBrush>
            </Button.Background>
        </Button>

    </Grid>
</Page>
