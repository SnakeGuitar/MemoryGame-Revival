<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- =========================================================
         Warm Rose / Crimson Palette
         ========================================================= -->
    <SolidColorBrush x:Key="PastelBackground"      Color="#FDF8F8"/>
    <SolidColorBrush x:Key="PastelPrimary"          Color="#C84747"/>
    <SolidColorBrush x:Key="PastelPrimaryHover"     Color="#B03A3A"/>
    <SolidColorBrush x:Key="PastelSecondary"        Color="#F4C2C2"/>
    <SolidColorBrush x:Key="PastelAccent"           Color="#F0A0A0"/>
    <SolidColorBrush x:Key="PastelText"             Color="#3D1C1C"/>
    <SolidColorBrush x:Key="PastelTextLight"        Color="#9B6B6B"/>
    <SolidColorBrush x:Key="PastelBorder"           Color="#EDD5D5"/>
    <SolidColorBrush x:Key="PastelError"            Color="#C84747"/>
    <SolidColorBrush x:Key="PastelSuccess"          Color="#B8F0D0"/>
    <SolidColorBrush x:Key="CardBackground"         Color="#D1F9F0F0"/>
    <SolidColorBrush x:Key="LinkText"               Color="#AF1010"/>
    <SolidColorBrush x:Key="LinkTextHover"          Color="#8A0D0D"/>

    <!-- Primary gradient — soft warm rose -->
    <LinearGradientBrush x:Key="PrimaryGradient" StartPoint="0.5,0" EndPoint="0.5,1">
        <GradientStop Color="#E07070" Offset="0"/>
        <GradientStop Color="#C04848" Offset="1"/>
    </LinearGradientBrush>

    <!-- Primary gradient hover (slightly darker) -->
    <LinearGradientBrush x:Key="PrimaryGradientHover" StartPoint="0.5,0" EndPoint="0.5,1">
        <GradientStop Color="#CC5555" Offset="0"/>
        <GradientStop Color="#A03030" Offset="1"/>
    </LinearGradientBrush>

    <!-- =========================================================
         Typography
         ========================================================= -->
    <FontFamily x:Key="DefaultFont">Segoe UI, Tahoma, Geneva, Verdana, sans-serif</FontFamily>

    <!-- =========================================================
         Corner Radii
         ========================================================= -->
    <CornerRadius x:Key="ButtonCornerRadius">24</CornerRadius>
    <CornerRadius x:Key="InputCornerRadius">8</CornerRadius>
    <CornerRadius x:Key="CardCornerRadius">18</CornerRadius>

    <!-- =========================================================
         Primary Button  (red gradient, white text)
         ========================================================= -->
    <Style x:Key="PastelButton" TargetType="Button">
        <Setter Property="Background"   Value="{StaticResource PrimaryGradient}"/>
        <Setter Property="Foreground"   Value="White"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="FontSize"     Value="14"/>
        <Setter Property="FontWeight"   Value="SemiBold"/>
        <Setter Property="FontFamily"   Value="{StaticResource DefaultFont}"/>
        <Setter Property="Cursor"       Value="Hand"/>
        <Setter Property="Padding"      Value="20,0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource ButtonCornerRadius}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource PrimaryGradientHover}"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.55"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Secondary Button (light rose, dark text) -->
    <Style x:Key="PastelButtonSecondary" TargetType="Button" BasedOn="{StaticResource PastelButton}">
        <Setter Property="Background" Value="{StaticResource PastelSecondary}"/>
        <Setter Property="Foreground" Value="{StaticResource PastelText}"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource PastelAccent}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Accent Button -->
    <Style x:Key="PastelButtonAccent" TargetType="Button" BasedOn="{StaticResource PastelButton}">
        <Setter Property="Background" Value="{StaticResource PastelAccent}"/>
        <Setter Property="Foreground" Value="{StaticResource PastelText}"/>
    </Style>

    <!-- =========================================================
         TextBox
         ========================================================= -->
    <Style x:Key="PastelTextBox" TargetType="TextBox">
        <Setter Property="Background"       Value="#FFFFFF"/>
        <Setter Property="Foreground"       Value="{StaticResource PastelText}"/>
        <Setter Property="BorderBrush"      Value="{StaticResource PastelBorder}"/>
        <Setter Property="BorderThickness"  Value="1.5"/>
        <Setter Property="FontSize"         Value="14"/>
        <Setter Property="FontFamily"       Value="{StaticResource DefaultFont}"/>
        <Setter Property="Padding"          Value="12,10"/>
        <Setter Property="CaretBrush"       Value="{StaticResource PastelText}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource InputCornerRadius}">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Margin="5,0,5,0"
                                      VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsFocused" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource PastelPrimary}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- =========================================================
         PasswordBox
         ========================================================= -->
    <Style x:Key="PastelPasswordBox" TargetType="PasswordBox">
        <Setter Property="Background"       Value="#FFFFFF"/>
        <Setter Property="Foreground"       Value="{StaticResource PastelText}"/>
        <Setter Property="BorderBrush"      Value="{StaticResource PastelBorder}"/>
        <Setter Property="BorderThickness"  Value="1.5"/>
        <Setter Property="FontSize"         Value="14"/>
        <Setter Property="FontFamily"       Value="{StaticResource DefaultFont}"/>
        <Setter Property="Padding"          Value="12,10"/>
        <Setter Property="CaretBrush"       Value="{StaticResource PastelText}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="PasswordBox">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource InputCornerRadius}">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      Margin="5,0,5,0"
                                      VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsFocused" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource PastelPrimary}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- =========================================================
         TextBlock Styles
         ========================================================= -->
    <Style x:Key="PastelTextBlock" TargetType="TextBlock">
        <Setter Property="Foreground"  Value="{StaticResource PastelText}"/>
        <Setter Property="FontFamily"  Value="{StaticResource DefaultFont}"/>
        <Setter Property="FontSize"    Value="14"/>
    </Style>

    <Style x:Key="PastelHeading" TargetType="TextBlock" BasedOn="{StaticResource PastelTextBlock}">
        <Setter Property="FontSize"   Value="26"/>
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>

    <Style x:Key="PastelLabel" TargetType="TextBlock" BasedOn="{StaticResource PastelTextBlock}">
        <Setter Property="FontSize"   Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource PastelTextLight}"/>
    </Style>

    <!-- =========================================================
         Link Button  (transparent bg, red text)
         ========================================================= -->
    <Style x:Key="LinkButton" TargetType="Button">
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Foreground"      Value="{StaticResource LinkText}"/>
        <Setter Property="Cursor"          Value="Hand"/>
        <Setter Property="FontSize"        Value="13"/>
        <Setter Property="FontWeight"      Value="SemiBold"/>
        <Setter Property="FontFamily"      Value="{StaticResource DefaultFont}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <TextBlock Text="{TemplateBinding Content}"
                               Foreground="{TemplateBinding Foreground}"
                               HorizontalAlignment="Center"
                               TextDecorations="Underline"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Foreground" Value="{StaticResource LinkTextHover}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- =========================================================
         Toggle Switch  (CheckBox styled as a pill switch)
         ========================================================= -->
    <Style x:Key="ToggleSwitch" TargetType="CheckBox">
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border x:Name="Track"
                                Width="46" Height="24"
                                CornerRadius="12"
                                Background="{StaticResource PastelBorder}">
                            <Grid>
                                <Ellipse x:Name="Thumb"
                                         Width="18" Height="18"
                                         Fill="White"
                                         HorizontalAlignment="Left"
                                         Margin="3,0,0,0"/>
                            </Grid>
                        </Border>
                        <ContentPresenter VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="Track"  Property="Background"          Value="{StaticResource PastelPrimary}"/>
                            <Setter TargetName="Thumb"  Property="HorizontalAlignment" Value="Right"/>
                            <Setter TargetName="Thumb"  Property="Margin"              Value="0,0,3,0"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- =========================================================
         ComboBox — full ControlTemplate matching the warm rose theme
         ========================================================= -->

    <!-- Item container: highlight on hover/selected -->
    <Style x:Key="PastelComboBoxItem" TargetType="ComboBoxItem">
        <Setter Property="FontFamily"       Value="{StaticResource DefaultFont}"/>
        <Setter Property="FontSize"         Value="14"/>
        <Setter Property="Foreground"       Value="{StaticResource PastelText}"/>
        <Setter Property="Padding"          Value="12,9"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="Cursor"           Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="Root"
                            Background="Transparent"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{StaticResource PastelSecondary}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{StaticResource PastelSecondary}"/>
                            <Setter Property="Foreground" Value="{StaticResource PastelPrimary}"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="PastelComboBox" TargetType="ComboBox">
        <Setter Property="Background"       Value="#FFFFFF"/>
        <Setter Property="Foreground"       Value="{StaticResource PastelText}"/>
        <Setter Property="BorderBrush"      Value="{StaticResource PastelBorder}"/>
        <Setter Property="BorderThickness"  Value="1.5"/>
        <Setter Property="FontSize"         Value="14"/>
        <Setter Property="FontFamily"       Value="{StaticResource DefaultFont}"/>
        <Setter Property="Padding"          Value="12,0"/>
        <Setter Property="Height"           Value="42"/>
        <Setter Property="Cursor"           Value="Hand"/>
        <Setter Property="ItemContainerStyle" Value="{StaticResource PastelComboBoxItem}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <!-- Main selection box -->
                        <Border x:Name="MainBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{StaticResource InputCornerRadius}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="36"/>
                                </Grid.ColumnDefinitions>

                                <!-- Selected item display -->
                                <ContentPresenter x:Name="ContentSite"
                                                  Grid.Column="0"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  Margin="{TemplateBinding Padding}"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left"
                                                  IsHitTestVisible="False"/>

                                <!-- Chevron arrow -->
                                <Path x:Name="Arrow"
                                      Grid.Column="1"
                                      Data="M 0 0 L 6 6 L 12 0"
                                      Stroke="{StaticResource PastelTextLight}"
                                      StrokeThickness="2"
                                      StrokeLineJoin="Round"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Width="12" Height="7"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Stretch="None"/>
                            </Grid>
                        </Border>

                        <!-- Toggle button (invisible, covers the whole box to open/close) -->
                        <ToggleButton IsChecked="{Binding IsDropDownOpen, Mode=TwoWay,
                                                          RelativeSource={RelativeSource TemplatedParent}}"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      Focusable="False"
                                      ClickMode="Press">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border Background="Transparent"/>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>

                        <!-- Dropdown popup -->
                        <Popup x:Name="PART_Popup"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               Placement="Bottom"
                               AllowsTransparency="True"
                               Focusable="False"
                               PopupAnimation="Slide">
                            <Border Background="#FFFFFF"
                                    BorderBrush="{StaticResource PastelBorder}"
                                    BorderThickness="1.5"
                                    CornerRadius="8"
                                    MinWidth="{Binding ActualWidth,
                                               RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                    MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                    Margin="0,3,0,0">
                                <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                              VerticalScrollBarVisibility="Auto">
                                    <ItemsPresenter/>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <!-- Open: highlight border in primary red -->
                        <Trigger Property="IsDropDownOpen" Value="True">
                            <Setter TargetName="MainBorder" Property="BorderBrush"
                                    Value="{StaticResource PastelPrimary}"/>
                            <Setter TargetName="Arrow" Property="Stroke"
                                    Value="{StaticResource PastelPrimary}"/>
                        </Trigger>
                        <!-- Mouse over -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="MainBorder" Property="BorderBrush"
                                    Value="{StaticResource PastelPrimary}"/>
                        </Trigger>
                        <!-- Disabled -->
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.55"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- =========================================================
         Slider
         ========================================================= -->
    <Style x:Key="PastelSlider" TargetType="Slider">
        <Setter Property="Foreground" Value="{StaticResource PastelPrimary}"/>
        <Setter Property="Minimum"    Value="0"/>
        <Setter Property="Maximum"    Value="1"/>
        <Setter Property="Height"     Value="20"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Slider">
                    <Grid VerticalAlignment="Center">
                        <Track x:Name="PART_Track">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="Slider.DecreaseLarge">
                                    <RepeatButton.Template>
                                        <ControlTemplate TargetType="RepeatButton">
                                            <Border Height="5" CornerRadius="2.5"
                                                    Background="{StaticResource PastelPrimary}"/>
                                        </ControlTemplate>
                                    </RepeatButton.Template>
                                </RepeatButton>
                            </Track.DecreaseRepeatButton>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="Slider.IncreaseLarge">
                                    <RepeatButton.Template>
                                        <ControlTemplate TargetType="RepeatButton">
                                            <Border Height="5" CornerRadius="2.5"
                                                    Background="{StaticResource PastelBorder}"/>
                                        </ControlTemplate>
                                    </RepeatButton.Template>
                                </RepeatButton>
                            </Track.IncreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb>
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Ellipse Width="18" Height="18"
                                                     Fill="{StaticResource PastelPrimary}"/>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- =========================================================
         Section Divider
         ========================================================= -->
    <Style x:Key="SectionDivider" TargetType="Rectangle">
        <Setter Property="Height"  Value="1"/>
        <Setter Property="Fill"    Value="{StaticResource PastelBorder}"/>
        <Setter Property="Margin"  Value="0,16,0,16"/>
    </Style>

    <!-- =========================================================
         Error Text
         ========================================================= -->
    <Style x:Key="PastelErrorText" TargetType="TextBlock">
        <Setter Property="Foreground"   Value="{StaticResource PastelError}"/>
        <Setter Property="FontFamily"   Value="{StaticResource DefaultFont}"/>
        <Setter Property="FontSize"     Value="12"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

</ResourceDictionary>
