<UserControl x:Class="MemoryGame.Client.Views.Session.VerifyEmailView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="800" d:DesignHeight="450">

    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="300">
            <TextBlock Text="Verify Email"
                       FontSize="24" FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,10" />

            <TextBlock Text="Enter the 6-digit PIN sent to your email."
                       TextWrapping="Wrap" TextAlignment="Center"
                       Margin="0,0,0,20" />

            <TextBox Text="{Binding Pin, UpdateSourceTrigger=PropertyChanged}"
                     MaxLength="6"
                     FontSize="24" TextAlignment="Center"
                     Height="40" Margin="0,0,0,10" />

            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="Red" TextWrapping="Wrap"
                       Margin="0,0,0,10"
                       Visibility="{Binding ErrorMessage, Converter={StaticResource NullToCollapsedConverter}}" />

            <Button Content="Verify"
                    Command="{Binding VerifyCommand}"
                    Height="35" Margin="0,0,0,10" />

            <Button Content="Resend PIN"
                    Command="{Binding ResendPinCommand}"
                    Height="30" Margin="0,0,0,5"
                    Style="{StaticResource LinkButton}" />

            <Button Content="Back"
                    Command="{Binding GoBackCommand}"
                    Height="30"
                    Style="{StaticResource LinkButton}" />
        </StackPanel>
    </Grid>
</UserControl>
