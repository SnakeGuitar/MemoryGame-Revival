<UserControl x:Class="MemoryGame.Client.Views.Session.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:MemoryGame.Client.Localization"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1280" d:DesignHeight="720">

    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="pack://application:,,,/Resources/Images/Backgrounds/background-minimalistic.png"
                        Stretch="UniformToFill"/>
        </Grid.Background>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Rectangle Grid.Column="0"
                       Width="280" Height="280"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Margin="40,0,0,0">
                <Rectangle.Fill>
                    <ImageBrush ImageSource="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=LogoImage}"
                                Stretch="Uniform"/>
                </Rectangle.Fill>
            </Rectangle>

            <Border Grid.Column="1"
                    Background="{StaticResource CardBackground}"
                    CornerRadius="{StaticResource CardCornerRadius}"
                    Width="360"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Padding="36,32"
                    Margin="0,0,40,0">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.14" Color="#3D1C1C"/>
                </Border.Effect>

                <StackPanel>
                    <TextBlock Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[Login_Title]}"
                               Style="{StaticResource PastelHeading}"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,24"/>

                    <TextBlock Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[Global_Label_Username]}"
                               Style="{StaticResource PastelLabel}"
                               Margin="0,0,0,6"/>
                    <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource PastelTextBox}"
                             Height="42" Margin="0,0,0,16"/>

                    <TextBlock Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[Global_Label_Password]}"
                               Style="{StaticResource PastelLabel}"
                               Margin="0,0,0,6"/>
                    <PasswordBox x:Name="PasswordBox"
                                 Style="{StaticResource PastelPasswordBox}"
                                 Height="42" Margin="0,0,0,16"/>

                    <TextBlock Text="{Binding ErrorMessage}"
                               Style="{StaticResource PastelErrorText}"
                               Margin="0,0,0,14"
                               Visibility="{Binding ErrorMessage, Converter={StaticResource NullToCollapsedConverter}}"/>

                    <Button Height="46"
                            Margin="0,0,0,16"
                            Command="{Binding LoginCommand}"
                            IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}">
                        <Button.Content>
                            <TextBlock Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[Global_Button_Login]}"
                                       FontFamily="{StaticResource DefaultFont}"
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="White"/>
                        </Button.Content>
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border CornerRadius="10" Padding="20,0">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                            <GradientStop Color="#FFC84747" Offset="0"/>
                                            <GradientStop Color="#FF963B3B" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Opacity" Value="0.55"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button HorizontalAlignment="Center"
                            Command="{Binding GoBackCommand}"
                            Content="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[Global_Button_Back]}"
                            Style="{StaticResource LinkButton}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
