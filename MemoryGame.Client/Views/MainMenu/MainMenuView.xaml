<UserControl x:Class="MemoryGame.Client.Views.MainMenu.MainMenuView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:MemoryGame.Client.Localization"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1280" d:DesignHeight="720">

    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="/Resources/Images/Backgrounds/katya-main.png"
                        Stretch="UniformToFill"/>
        </Grid.Background>

        <StackPanel HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Width="500">

            <Image Source="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=LogoImage}"
                   Height="280"
                   HorizontalAlignment="Center"
                   Stretch="Uniform"
                   Margin="0,0,0,20"/>

            <Border Margin="60,0,60,0"
                    CornerRadius="{StaticResource CardCornerRadius}"
                    Background="{StaticResource CardBackground}"
                    Padding="32,28,32,24">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="4" BlurRadius="20"
                                      Color="#C84747" Opacity="0.12"/>
                </Border.Effect>

                <StackPanel>

                    <TextBlock Text="{Binding WelcomeMessage}"
                               Style="{StaticResource PastelTextBlock}"
                               FontSize="17" FontWeight="SemiBold"
                               Foreground="{StaticResource PastelPrimary}"
                               HorizontalAlignment="Center"
                               TextAlignment="Center"
                               Margin="0,0,0,20"
                               TextWrapping="Wrap"/>

                    <Button Height="48" Margin="0,0,0,12"
                            Style="{StaticResource PastelButton}"
                            Content="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[MainMenu_Button_Singleplayer]}"/>

                    <Button Height="48" Margin="0,0,0,12"
                            Style="{StaticResource PastelButton}"
                            Content="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[MainMenu_Button_Multiplayer]}"/>

                    <Button Height="48" Margin="0,0,0,20"
                            Style="{StaticResource PastelButton}"
                            Command="{Binding GoToMoreCommand}"
                            Content="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[MainMenu_Button_More]}"/>

                    <Rectangle Style="{StaticResource SectionDivider}" Margin="20,0,20,4"/>

                    <Button HorizontalAlignment="Center"
                            Command="{Binding LogoutCommand}"
                            Content="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[Global_Button_Logout]}"
                            Style="{StaticResource LinkButton}"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
