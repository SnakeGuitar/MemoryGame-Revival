<UserControl x:Class="MemoryGame.Client.Views.MainMenu.MainMenuView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:MemoryGame.Client.Localization"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1280" d:DesignHeight="720">

    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="pack://application:,,,/Resources/Images/Backgrounds/background-minimalistic.png"
                        Stretch="UniformToFill"/>
        </Grid.Background>

        <StackPanel VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Width="260">

            <!-- Welcome -->
            <TextBlock Text="{Binding WelcomeMessage}"
                       FontFamily="{StaticResource DefaultFont}"
                       FontSize="18" FontWeight="SemiBold"
                       Foreground="{StaticResource PastelText}"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,32"/>

            <!-- Singleplayer -->
            <Button Height="46" Margin="0,0,0,12">
                <Button.Content>
                    <TextBlock Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[MainMenu_Button_Singleplayer]}"
                               FontFamily="{StaticResource DefaultFont}" FontSize="14" FontWeight="SemiBold" Foreground="White"/>
                </Button.Content>
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="10" Padding="20,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                    <GradientStop Color="#FFC84747" Offset="0"/>
                                    <GradientStop Color="#FF963B3B" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- Multiplayer -->
            <Button Height="46" Margin="0,0,0,12">
                <Button.Content>
                    <TextBlock Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[MainMenu_Button_Multiplayer]}"
                               FontFamily="{StaticResource DefaultFont}" FontSize="14" FontWeight="SemiBold" Foreground="White"/>
                </Button.Content>
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="10" Padding="20,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                    <GradientStop Color="#FFC84747" Offset="0"/>
                                    <GradientStop Color="#FF963B3B" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- Profile -->
            <Button Height="46" Margin="0,0,0,12">
                <Button.Content>
                    <TextBlock Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[MainMenu_Button_Profile]}"
                               FontFamily="{StaticResource DefaultFont}" FontSize="14" FontWeight="SemiBold" Foreground="White"/>
                </Button.Content>
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="10" Padding="20,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                    <GradientStop Color="#FFC84747" Offset="0"/>
                                    <GradientStop Color="#FF963B3B" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- Friends -->
            <Button Height="46" Margin="0,0,0,12">
                <Button.Content>
                    <TextBlock Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[MainMenu_Button_Friends]}"
                               FontFamily="{StaticResource DefaultFont}" FontSize="14" FontWeight="SemiBold" Foreground="White"/>
                </Button.Content>
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="10" Padding="20,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                    <GradientStop Color="#FFC84747" Offset="0"/>
                                    <GradientStop Color="#FF963B3B" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- Settings (wired to command) -->
            <Button Height="46"
                    Margin="0,0,0,24"
                    Command="{Binding GoToSettingsCommand}">
                <Button.Content>
                    <TextBlock Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[MainMenu_Button_Settings]}"
                               FontFamily="{StaticResource DefaultFont}" FontSize="14" FontWeight="SemiBold" Foreground="White"/>
                </Button.Content>
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="10" Padding="20,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                    <GradientStop Color="#FFC84747" Offset="0"/>
                                    <GradientStop Color="#FF963B3B" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- Logout link -->
            <Button HorizontalAlignment="Center"
                    Command="{Binding LogoutCommand}"
                    Content="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[Global_Button_Logout]}"
                    Style="{StaticResource LinkButton}"/>
        </StackPanel>
    </Grid>
</UserControl>
