<UserControl x:Class="MemoryGame.Client.Views.Profile.ProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:MemoryGame.Client.Localization"
             xmlns:converters="clr-namespace:MemoryGame.Client.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1280" d:DesignHeight="720">

    <UserControl.Resources>
        <converters:ByteArrayToImageConverter x:Key="ByteArrayToImage"/>
    </UserControl.Resources>

    <Grid>
        <!-- Background -->
        <Grid.Background>
            <ImageBrush ImageSource="pack://application:,,,/Resources/Images/Backgrounds/background-minimalistic.png"
                        Stretch="UniformToFill"/>
        </Grid.Background>

        <!-- Centered content -->
        <Grid VerticalAlignment="Center" HorizontalAlignment="Center"
              MaxWidth="820">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ══ Profile Card ══ -->
            <Border Grid.Row="0"
                    Background="{StaticResource CardBackground}"
                    CornerRadius="{StaticResource CardCornerRadius}"
                    Padding="40,36"
                    Margin="20">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.14" Color="#3D1C1C"/>
                </Border.Effect>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- LEFT: Avatar + action buttons -->
                    <StackPanel Grid.Column="0" VerticalAlignment="Top" Margin="0,0,36,0">
                        <!-- Avatar -->
                        <Border Width="140" Height="140"
                                CornerRadius="70"
                                BorderBrush="{StaticResource PastelPrimary}"
                                BorderThickness="3"
                                HorizontalAlignment="Center"
                                Background="#10C84747">
                            <Grid>
                                <!-- Placeholder when no avatar -->
                                <TextBlock Text="👤"
                                           FontSize="48"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Visibility="{Binding AvatarBytes, Converter={StaticResource NullToCollapsedConverter}, ConverterParameter=invert}"/>
                                <!-- Avatar image -->
                                <Border CornerRadius="68" ClipToBounds="True">
                                    <Image Source="{Binding AvatarBytes, Converter={StaticResource ByteArrayToImage}}"
                                           Stretch="UniformToFill"
                                           Width="134" Height="134"
                                           Visibility="{Binding AvatarBytes, Converter={StaticResource NullToCollapsedConverter}}"/>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- Edit Profile -->
                        <Button Margin="0,16,0,0"
                                HorizontalAlignment="Center"
                                Style="{StaticResource PastelButtonSecondary}"
                                Height="36" Padding="20,0"
                                Command="{Binding GoToEditProfileCommand}"
                                Content="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[EditProfile_Label_EditProfile]}"/>

                        <!-- Logout -->
                        <Button Margin="0,8,0,0"
                                HorizontalAlignment="Center"
                                Command="{Binding LogoutCommand}"
                                Content="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[Global_Button_Logout]}"
                                Style="{StaticResource LinkButton}"
                                Foreground="{StaticResource PastelPrimary}"/>
                    </StackPanel>

                    <!-- RIGHT: User info -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <!-- Username (large heading) -->
                        <TextBlock Text="{Binding Username}"
                                   Style="{StaticResource PastelHeading}"
                                   FontSize="32"
                                   Margin="0,0,0,16"
                                   TextTrimming="CharacterEllipsis"/>

                        <!-- Name -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[Profile_Label_Name]}"
                                       Style="{StaticResource PastelLabel}"
                                       FontSize="13"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding FullName}"
                                       Style="{StaticResource PastelTextBlock}"
                                       FontSize="15"
                                       Foreground="{StaticResource PastelPrimary}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Email -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[Global_Label_Email]}"
                                       Style="{StaticResource PastelLabel}"
                                       FontSize="13"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Email}"
                                       Style="{StaticResource PastelTextBlock}"
                                       FontSize="15"
                                       Foreground="{StaticResource PastelPrimary}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Registration Date -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[Profile_Label_RegistrationDate]}"
                                       Style="{StaticResource PastelLabel}"
                                       FontSize="13"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding RegistrationDate}"
                                       Style="{StaticResource PastelTextBlock}"
                                       FontSize="15"
                                       Foreground="{StaticResource PastelPrimary}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Social Networks -->
                        <StackPanel Margin="0,8,0,0"
                                    Visibility="{Binding HasSocialNetworks, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[Profile_Label_SocialNetworks]}"
                                       Style="{StaticResource PastelLabel}"
                                       FontSize="13"
                                       Margin="0,0,0,6"/>

                            <ItemsControl ItemsSource="{Binding SocialNetworks}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Margin="8,2,0,2">
                                            <TextBlock Text="•"
                                                       Style="{StaticResource PastelTextBlock}"
                                                       Foreground="{StaticResource PastelPrimary}"
                                                       Margin="0,0,6,0"/>
                                            <TextBlock Text="{Binding Account}"
                                                       Style="{StaticResource PastelTextBlock}"
                                                       Foreground="{StaticResource PastelPrimary}"
                                                       FontSize="14"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ══ Bottom navigation buttons ══ -->
            <StackPanel Grid.Row="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,20">

                <Button Style="{StaticResource PastelButton}"
                        Height="42" Padding="28,0"
                        Margin="0,0,12,0"
                        Command="{Binding GoToFriendsCommand}"
                        Content="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[MainMenu_Button_Friends]}"/>

                <Button Style="{StaticResource PastelButtonSecondary}"
                        Height="42" Padding="28,0"
                        Margin="0,0,12,0"
                        Content="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[StatsHistory_Title]}"/>

                <Button HorizontalAlignment="Center"
                        Style="{StaticResource LinkButton}"
                        Command="{Binding GoBackCommand}"
                        Content="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[Global_Button_Back]}"
                        VerticalAlignment="Center"
                        Margin="12,0,0,0"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
