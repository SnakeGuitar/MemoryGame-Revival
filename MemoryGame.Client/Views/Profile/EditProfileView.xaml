<UserControl x:Class="MemoryGame.Client.Views.Profile.EditProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:MemoryGame.Client.Localization"
             xmlns:converters="clr-namespace:MemoryGame.Client.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1280" d:DesignHeight="720">

    <UserControl.Resources>
        <converters:ByteArrayToImageConverter x:Key="ByteArrayToImage"/>
    </UserControl.Resources>

    <Grid>
        <Grid.Background>
            <ImageBrush ImageSource="pack://application:,,,/Resources/Images/Backgrounds/background-minimalistic.png"
                        Stretch="UniformToFill"/>
        </Grid.Background>

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Style="{StaticResource PastelScrollViewer}">

            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        MaxWidth="880"
                        Margin="20,40,20,40">

                <!-- Title -->
                <TextBlock Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[EditProfile_Label_EditProfile]}"
                           Style="{StaticResource PastelHeading}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,20"/>

                <!-- ══ Main Card ══ -->
                <Border Background="{StaticResource CardBackground}"
                        CornerRadius="{StaticResource CardCornerRadius}"
                        Padding="36,32"
                        Margin="0,0,0,20">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.14" Color="#3D1C1C"/>
                    </Border.Effect>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- ═══ LEFT COLUMN ═══ -->
                        <StackPanel Grid.Column="0">

                            <!-- ── Avatar Section ── -->
                            <TextBlock Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[Global_Label_Avatar]}"
                                       Style="{StaticResource PastelLabel}"
                                       Margin="0,0,0,10"/>

                            <StackPanel Orientation="Horizontal"
                                        HorizontalAlignment="Center"
                                        Margin="0,0,0,8">
                                <!-- Avatar preview -->
                                <Border Width="90" Height="90"
                                        CornerRadius="45"
                                        BorderBrush="{StaticResource PastelPrimary}"
                                        BorderThickness="2"
                                        Background="#10C84747"
                                        Margin="0,0,16,0">
                                    <Grid>
                                        <TextBlock Text="👤" FontSize="30"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Visibility="{Binding AvatarBytes, Converter={StaticResource NullToCollapsedConverter}, ConverterParameter=invert}"/>
                                        <Border CornerRadius="43" ClipToBounds="True">
                                            <Image Source="{Binding AvatarBytes, Converter={StaticResource ByteArrayToImage}}"
                                                   Stretch="UniformToFill"
                                                   Width="86" Height="86"
                                                   Visibility="{Binding AvatarBytes, Converter={StaticResource NullToCollapsedConverter}}"/>
                                        </Border>
                                    </Grid>
                                </Border>

                                <Button VerticalAlignment="Center"
                                        Style="{StaticResource PastelButtonSecondary}"
                                        Padding="16,6"
                                        Command="{Binding ChangeAvatarCommand}"
                                        Content="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[EditProfile_Button_ChangeAvatar]}" Width="229"/>
                            </StackPanel>

                            <Rectangle Style="{StaticResource SectionDivider}"/>

                            <!-- ── Personal Info ── -->
                            <TextBlock Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[EditProfile_Label_PersonalInfo]}"
                                       Style="{StaticResource PastelLabel}"
                                       Margin="0,0,0,8"/>

                            <TextBlock Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[Profile_Label_Name]}"
                                       Style="{StaticResource PastelLabel}"
                                       Margin="0,0,0,4"/>
                            <TextBox Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource PastelTextBox}"
                                     Margin="0,0,0,8"/>

                            <TextBlock Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[Global_Label_Username]}"
                                       Style="{StaticResource PastelLabel}"
                                       Margin="0,0,0,4"/>
                            <TextBox Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource PastelTextBox}"
                                     Margin="0,0,0,8"/>

                            <Button Style="{StaticResource PastelButton}"
                                    Padding="20,8"
                                    HorizontalAlignment="Right"
                                    Command="{Binding UpdatePersonalInfoCommand}"
                                    Content="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[Global_Button_Update]}" Width="150"/>

                            <Rectangle Style="{StaticResource SectionDivider}"/>

                            <!-- ── Social Networks ── -->
                            <TextBlock Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[Profile_Label_SocialNetworks]}"
                                       Style="{StaticResource PastelLabel}"
                                       Margin="0,0,0,8"/>

                            <ItemsControl ItemsSource="{Binding SocialNetworks}"
                                          Margin="0,0,0,8">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Account}"
                                                       Style="{StaticResource PastelTextBlock}"
                                                       Foreground="{StaticResource PastelPrimary}"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"/>

                                            <Button Grid.Column="1"
                                                    Content="✕"
                                                    Style="{StaticResource PastelButtonDanger}"
                                                    Width="30" Height="28"
                                                    Padding="0"
                                                    FontSize="11"
                                                    Command="{Binding DataContext.RemoveSocialCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding Id}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Add new social -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBox Grid.Column="0"
                                         Text="{Binding NewSocialAccount, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource PastelTextBox}"
                                         Margin="0,0,8,0"/>

                                <Button Grid.Column="1"
                                        Content="+"
                                        Style="{StaticResource PastelButton}"
                                        Width="40"
                                        Padding="0"
                                        FontSize="18"
                                        Command="{Binding AddSocialCommand}"/>
                            </Grid>
                        </StackPanel>

                        <!-- ═══ RIGHT COLUMN ═══ -->
                        <StackPanel Grid.Column="2">

                            <!-- ── Change Username ── -->
                            <TextBlock Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[EditProfile_Label_ChangeUsername]}"
                                       Style="{StaticResource PastelLabel}"
                                       Margin="0,0,0,8"/>

                            <TextBlock Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[EditProfile_Label_NewUsername]}"
                                       Style="{StaticResource PastelLabel}"
                                       Margin="0,0,0,4"/>
                            <TextBox Text="{Binding NewUsername, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource PastelTextBox}"
                                     Margin="0,0,0,8"/>

                            <Button Style="{StaticResource PastelButton}"
                                    Padding="20,8"
                                    HorizontalAlignment="Right"
                                    Command="{Binding UpdateUsernameCommand}"
                                    Content="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[Global_Button_Update]}" Width="150"/>

                            <Rectangle Style="{StaticResource SectionDivider}" Margin="0,20,0,20"/>

                            <!-- ── Change Password ── -->
                            <TextBlock Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[EditProfile_Button_UpdatePassword]}"
                                       Style="{StaticResource PastelLabel}"
                                       Margin="0,0,0,8"/>

                            <TextBlock Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[EditProfile_Label_ActualPassword]}"
                                       Style="{StaticResource PastelLabel}"
                                       Margin="0,0,0,4"/>
                            <PasswordBox Style="{StaticResource PastelPasswordBox}"
                                         Margin="0,0,0,8"
                                         PasswordChanged="CurrentPassword_PasswordChanged"/>

                            <TextBlock Text="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[EditProfile_Label_NewPassword]}"
                                       Style="{StaticResource PastelLabel}"
                                       Margin="0,0,0,4"/>
                            <PasswordBox Style="{StaticResource PastelPasswordBox}"
                                         Margin="0,0,0,8"
                                         PasswordChanged="NewPassword_PasswordChanged"/>

                            <Button Style="{StaticResource PastelButton}"
                                    Padding="20,8"
                                    HorizontalAlignment="Right"
                                    Command="{Binding UpdatePasswordCommand}"
                                    Content="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[Global_Button_Update]}" Width="150"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Back button -->
                <Button HorizontalAlignment="Center"
                        Command="{Binding GoBackCommand}"
                        Content="{Binding Source={x:Static loc:LocalizationManager.Instance}, Path=[Global_Button_Back]}"
                        Style="{StaticResource LinkButton}"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
